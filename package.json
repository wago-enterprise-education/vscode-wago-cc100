{
  "name": "vscode-wago-cc100",
  "displayName": "WAGO CC100",
  "description": "VS Code extension to develop python scripts for the WAGO CC100 programmable logic controller",
  "version": "0.1.11",
  "author": {
    "name": "WAGO Education",
    "email": "ausbildungminden@wago.com",
    "url": "https://github.com/wago-enterprise-education"
  },
  "contributors": [
    {
      "name": "André Bell"
    },
    {
      "name": "Maik Rehburg"
    },
    {
      "name": "Florian Deerberg"
    },
    {
      "name": "Andreas Epp"
    },
    {
      "name": "William Epp"
    },
    {
      "name": "Fabian Henßler"
    },
    {
      "name": "Alexander Nungesser"
    },
    {
      "name": "Marius Rösner"
    },
    {
      "name": "Max Steidle"
    }
  ],
  "publisher": "WAGO-education",
  "license": "see LICENSE file",
  "homepage": "https://github.com/wago-enterprise-education/vscode-wago-cc100",
  "bugs": {
    "url": "https://github.com/wago-enterprise-education/vscode-wago-cc100/issues"
  },
  "qna": "https://github.com/wago-enterprise-education/vscode-wago-cc100/discussions",
  "repository": {
    "type": "git",
    "url": "https://github.com/wago-enterprise-education/vscode-wago-cc100.git"
  },
  "icon": "res/images/WAGOW.png",
  "type": "commonjs",
  "engines": {
    "vscode": "^1.63.0"
  },
  "galleryBanner": {
    "color": "white",
    "theme": "light"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-wago-cc100.application_upload",
        "title": "Upload application to CC100"
      },
      {
        "command": "vscode-wago-cc100.iocheck",
        "title": "IO-Check",
        "icon": "$(eye)"
      },
      {
        "command": "vscode-wago-cc100.testSSH",
        "title": "Test SSH"
      },
      {
        "command": "vscode-wago-cc100.add-controller",
        "title": "Add Controller",
        "icon": "$(add)"
      },
      {
        "command": "vscode-wago-cc100.upload",
        "title": "Upload",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "vscode-wago-cc100.edit-setting",
        "title": "Edit Setting",
        "icon": "$(pencil)"
      },
      {
        "command": "vscode-wago-cc100.remove-controller",
        "title": "Remove Controller",
        "icon": "$(remove)"
      },
      {
        "command": "vscode-wago-cc100.refresh-view",
        "title": "Refresh View",
        "icon": "$(sync)"
      },
      {
        "command": "vscode-wago-cc100.init-project",
        "title": "Init Project"
      },
      {
        "command": "vscode-wago-cc100.create-project",
        "title": "Create Project"
      }
    ],
    "viewsWelcome": [
      {
        "view": "no-folder-view",
        "contents": "In order to use this extension, you need to open a folder containing a CC100 project. \n [Create Project](command:vscode-wago-cc100.create-project) \n [Open Project](command:vscode.openFolder) \n To learn more about the extension read the [documentation](https://github.com/wago-enterprise-education/vscode-wago-cc100/blob/main/README.md)."
      },
      {
        "view": "no-project-view",
        "contents": "The folder you opened does not contain a CC100 project. \n [Init Project](command:vscode-wago-cc100.init-project) \n To learn more about the extension read the [documentation](https://github.com/wago-enterprise-education/vscode-wago-cc100/blob/main/README.md)."
      },
      {
        "view": "controller-view",
        "contents": "No controller added yet. \n [Add Controller](command:vscode-wago-cc100.add-controller) \n To learn more about the extension read the [documentation](https://github.com/wago-enterprise-education/vscode-wago-cc100/blob/main/README.md)."
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "CC100",
          "title": "WAGO CC100",
          "icon": "res/images/WAGOW.png"
        }
      ]
    },
    "views": {
      "CC100": [
        {
          "name": "Controller",
          "id": "controller-view",
          "when": "workspaceFolderCount > 0 && wagoYamlPresent"
        },
        {
          "name": "No Folder Opened",
          "id": "no-folder-view",
          "when": "workspaceFolderCount == 0"
        },
        {
          "name": "No CC100 Project Found",
          "id": "no-project-view",
          "when": "workspaceFolderCount > 0 && !wagoYamlPresent"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "vscode-wago-cc100.add-controller",
          "when": "view == controller-view",
          "group": "navigation@2"
        },
        {
          "command": "vscode-wago-cc100.refresh-view",
          "when": "view == controller-view",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "vscode-wago-cc100.upload",
          "when": "view == controller-view  && viewItem == controller",
          "group": "inline@4"
        },
        {
          "command": "vscode-wago-cc100.iocheck",
          "when": "view == controller-view && viewItem == controller",
          "group": "inline@3"
        },
        {
          "command": "vscode-wago-cc100.edit-setting",
          "when": "view == controller-view && viewItem == controller",
          "group": "inline@2"
        },
        {
          "command": "vscode-wago-cc100.remove-controller",
          "when": "view == controller-view && viewItem == controller",
          "group": "inline@1"
        },
        {
          "command": "vscode-wago-cc100.edit-setting",
          "when": "view == controller-view && viewItem == controllerItem",
          "group": "inline"
        }
      ]
    }
  },
  "extensionDependencies": [
    "ms-python.python",
    "mindaro-dev.file-downloader"
  ],
  "dependencies": {
    "@microsoft/vscode-file-downloader-api": "^1.0.1",
    "node-ssh": "^13.1.0",
    "sanitize-html": "^2.14.0",
    "ssh2": "^1.15.0",
    "typescript": "^5.3.3",
    "yaml": "^2.7.0"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "vscode-test",
    "deploy": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "@types/sanitize-html": "^2.13.0",
    "@types/ssh2": "^1.15.4",
    "@types/vscode": "^1.63.0",
    "@types/yaml": "^1.9.6",
    "@vscode/vsce": "^3.2.1"
  }
}
